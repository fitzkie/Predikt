generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Unified user model — one USD balance usable for both Sports and Predikts
model PrediktsUser {
  id              String   @id @default(cuid())
  walletAddress   String   @unique
  privyUserId     String?  @unique
  email           String?
  depositAddress  String?  @unique
  depositPrivKey  String?  // AES-256-GCM encrypted: iv:authTag:ciphertext (hex)
  usdBalance      Decimal  @default(0) @db.Decimal(18, 6)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orders          PrediktsOrder[]
  deposits        PrediktsDeposit[]
  sportsBets      SportsBet[]

  @@map("predikts_users")
}

model PrediktsDeposit {
  id            String   @id @default(cuid())
  userId        String
  user          PrediktsUser @relation(fields: [userId], references: [id])
  txHash        String   @unique
  amountUsd     Decimal  @db.Decimal(18, 6)
  token         String   @default("USDC")  // USDC | USDT
  status        String   @default("confirmed")
  createdAt     DateTime @default(now())

  @@map("predikts_deposits")
}

model PrediktsOrder {
  id              String   @id @default(cuid())
  userId          String
  user            PrediktsUser @relation(fields: [userId], references: [id])
  polyOrderId     String?
  tokenId         String
  marketQuestion  String?
  marketSlug      String?
  side            String
  amount          Decimal  @db.Decimal(18, 6)
  price           Float
  orderType       String   @default("MARKET")
  status          String   @default("pending")
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("predikts_orders")
}

model SportsBet {
  id              String   @id @default(cuid())
  userId          String
  user            PrediktsUser @relation(fields: [userId], references: [id])
  conditionId     String
  outcomeId       String
  odds            Float
  amount          Decimal  @db.Decimal(18, 6)
  potentialPayout Decimal  @db.Decimal(18, 6)
  status          String   @default("pending") // pending | won | lost | refunded | canceled
  txHash          String?
  azuroBetId      String?
  marketName      String?
  selectionName   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("sports_bets")
}

// Unified withdrawals (actual payouts to user wallet)
model Withdrawal {
  id            String   @id @default(cuid())
  walletAddress String
  source        String   // "sports" | "predikts"
  amountUsd     Decimal  @db.Decimal(18, 6)
  token         String   // "USDT" | "USDC"
  txHash        String?  @unique
  status        String   @default("pending") // pending | processing | completed | failed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("withdrawals")
}
