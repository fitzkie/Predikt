generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PrediktsUser {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  pUsdBalance   Decimal  @default(0) @db.Decimal(18, 6)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        PrediktsOrder[]
  deposits      PrediktsDeposit[]

  @@map("predikts_users")
}

model PrediktsDeposit {
  id            String   @id @default(cuid())
  userId        String
  user          PrediktsUser @relation(fields: [userId], references: [id])
  txHash        String   @unique
  amountUsdc    Decimal  @db.Decimal(18, 6)
  status        String   @default("confirmed")
  createdAt     DateTime @default(now())

  @@map("predikts_deposits")
}

model PrediktsOrder {
  id              String   @id @default(cuid())
  userId          String
  user            PrediktsUser @relation(fields: [userId], references: [id])
  polyOrderId     String?
  tokenId         String
  marketQuestion  String?
  marketSlug      String?
  side            String
  amount          Decimal  @db.Decimal(18, 6)
  price           Float
  orderType       String   @default("MARKET")
  status          String   @default("pending")
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("predikts_orders")
}

// ── Sports custodial model ───────────────────────────────────────────────────

model SportsUser {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  usdtBalance   Decimal  @default(0) @db.Decimal(18, 6)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  bets          SportsBet[]
  deposits      SportsDeposit[]

  @@map("sports_users")
}

model SportsBet {
  id              String   @id @default(cuid())
  userId          String
  user            SportsUser @relation(fields: [userId], references: [id])
  conditionId     String
  outcomeId       String
  odds            Float
  amount          Decimal  @db.Decimal(18, 6)
  potentialPayout Decimal  @db.Decimal(18, 6)
  status          String   @default("pending") // pending | won | lost | refunded
  txHash          String?
  azuroBetId      String?
  marketName      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("sports_bets")
}

model SportsDeposit {
  id            String   @id @default(cuid())
  userId        String
  user          SportsUser @relation(fields: [userId], references: [id])
  txHash        String   @unique
  amountUsdt    Decimal  @db.Decimal(18, 6)
  status        String   @default("confirmed")
  createdAt     DateTime @default(now())

  @@map("sports_deposits")
}

// ── Unified withdrawals (actual payouts to user wallet) ──────────────────────

model Withdrawal {
  id            String   @id @default(cuid())
  walletAddress String
  source        String   // "sports" | "predikts"
  amountUsd     Decimal  @db.Decimal(18, 6)
  token         String   // "USDT" | "USDC"
  txHash        String?  @unique
  status        String   @default("pending") // pending | processing | completed | failed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("withdrawals")
}
