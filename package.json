{
  "name": "sdk-example",
  "version": "3.0.0",
  "engines": {
    "node": ">=22.11.0"
  },
  "private": true,
  "scripts": {
    "dev": "npm run watch-icons & next dev",
    "build": "npm run build-icons && prisma generate && next build",
    "migrate": "prisma db push --accept-data-loss",
    "start": "mkdir -p .next/standalone/.next && cp -R .next/static .next/standalone/.next/static && cp -R public .next/standalone/public && cp -R node_modules/.prisma .next/standalone/node_modules/.prisma 2>/dev/null; cp -R node_modules/@prisma .next/standalone/node_modules/@prisma 2>/dev/null; cp -R prisma .next/standalone/prisma 2>/dev/null; prisma db push --accept-data-loss && HOSTNAME=0.0.0.0 PORT=${PORT:-3000} node .next/standalone/server.js",
    "lint-ts": "tsc --noEmit",
    "lint": "next lint && tsc --noEmit",
    "test:contracts:azuro": "node scripts/test-azuro-contracts.mjs",
    "test:contracts:polymarket": "node scripts/test-polymarket-contracts.mjs",
    "------  Icons --------------------------------------------------------------------------": "",
    "watch-icons": "node bin/icons --watch",
    "build-icons": "node bin/icons"
  },
